# Copy this file to .env for local development
# On Elastic Beanstalk, set these via Environment Properties

NODE_ENV=development
PORT=8080

# RDS PostgreSQL Connection
# (Elastic Beanstalk auto-injects RDS_* vars when you attach an RDS instance)
RDS_HOSTNAME=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=5432
RDS_DB_NAME=postgres
RDS_USERNAME=postgres
RDS_PASSWORD=postgrespass
